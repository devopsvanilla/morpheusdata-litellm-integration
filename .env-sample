# Exemplo de arquivo .env para a implantação local

# URL do Ollama dentro do Docker Compose
OLLAMA_URL=http://ollama:11434

# Nome do modelo usado pelo Ollama e LiteLLM
OLLAMA_MODEL_NAME=llama3.2:3b
LITELLM_MODEL_REF=ollama/llama3.2:3b
LITELLM_MODEL_ALIAS=local-llama

# Chave mestre do LiteLLM
LITELLM_MASTER_KEY=sk-local-morpheus-001

# URL do LiteLLM para testes locais
LITELLM_URL=http://localhost:4000
